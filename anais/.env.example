DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/anais?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Opcional: desarrollo sin invitación (no uses en producción)
# ALLOW_OPEN_REGISTER="true"

# Respuestas simuladas del creador (typing + mensaje retardado + candados aleatorios)
# SIMULATED_CREATOR_REPLIES="true"
# Retardo simulado (ms): mayor nivel VIP → más rápido; prioridad del miembro acelera un ~30%
# SIMULATED_REPLY_MS_MIN="2000"
# SIMULATED_REPLY_MS_MAX="5500"

# Reenganche suave tras inactividad (ms)
# REENGAGE_AFTER_MS="300000"

# Job retención (server.ts): notificaciones in-app periódicas
# RETENTION_TICK_MS="900000"

# Cierre de sesión por inactividad (ms), solo miembros — SecurityChrome
# NEXT_PUBLIC_IDLE_LOGOUT_MS="1500000"

# Si Socket.io está en otro origen (split deploy)
# NEXT_PUBLIC_SOCKET_URL="https://socket.tu-dominio.com"

# Seed
# SEED_ADMIN_EMAIL="admin@anais.local"
# SEED_ADMIN_PASSWORD="..."

# Creador del hilo (por defecto: primer admin)
# CREATOR_USER_ID=""
